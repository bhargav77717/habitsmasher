# Admin login password. Admin ID is fixed as "admin".
ADMIN_PASSWORD=changeme123

# Random long string used to sign login sessions. Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-this-with-a-long-random-string

# These are auto-added by Vercel when you attach a "Redis" storage
# integration from the Vercel Marketplace — you do NOT set these by hand
# in production. Only listed here so local `next dev` knows what to expect.
KV_REDIS_URL=
